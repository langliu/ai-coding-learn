   "source": [
    "from dotenv import load_dotenv\n",
    "from openai import OpenAI\n",
    "\n",
    "load_dotenv()\n",
    "\n",
    "client = OpenAI()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "72f6ac6c",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/plain": [
       "'我可以帮你做很多事，常见包括：\\n\\n- **回答问题与解释概念**：从日常疑问到专业知识梳理（学习、工作、技术、生活等）。\\n- **写作与润色**：文章、邮件、报告、文案、简历、演讲稿；也能改写让表达更清晰/更正式/更有文采。\\n- **翻译**：中英互译、润色式翻译（尽量保留语气与语境）。\\n- **代码与技术支持**：写/改代码、解释报错、给出实现思路（如 Python、JavaScript、Java 等；也能做伪代码/算法思路）。\\n- **学习辅导**：制定学习计划、出题、讲题、总结知识点、做复习提纲。\\n- **头脑风暴**：项目想法、产品方案、活动策划、命名、创意生成。\\n- **数据与文本处理**：帮你分析信息、提炼要点、生成表格草案、整理大纲。\\n- **情景对话与角色扮演**：面试模拟、客服话术、辩论练习、英文口语练习等。\\n\\n如果你告诉我：**你想做什么 + 目标/场景 + 需要的语言和格式**（比如要简短还是详细、要中文还是英文），我就能更精准地帮你。你现在最想让我帮你做哪一件事？'"
      ]
     },
     "execution_count": 3,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "res = client.chat.completions.create(\n",
    "    model=\"gpt-5.4-nano\", messages=[{\"role\": \"user\", \"content\": \"你能做些什么？\"}]\n",
    ")\n",
    "\n",
    "res.choices[0].message.content"
   ]
  }
 ],
