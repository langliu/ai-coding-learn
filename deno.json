{
  "tasks": {
    "dev": "deno run --watch main.ts",
    "demo:01": "deno run --env-file=.env -P outparset/demo-01.ts"
  },
  "imports": {
    "@langchain/core": "npm:@langchain/core@^1.1.29",
    "@langchain/deepseek": "npm:@langchain/deepseek@^1.0.15",
    "@langchain/openai": "npm:@langchain/openai@^1.2.12",
    "@std/assert": "jsr:@std/assert@1",
    "lodash": "npm:lodash@^4.17.23",
    "oxfmt": "npm:oxfmt@^0.38.0"
  },
  "deno.enable": true,
  "permissions": {
    "default": {
      "env": [
        "DEEPSEEK_API_KEY",
        "LC_OUTPUT_VERSION",
        "OPENAI_ORGANIZATION",
        "LANGCHAIN_VERBOSE",
        "LANGSMITH_TRACING_V2",
        "LANGCHAIN_TRACING_V2",
        "LANGSMITH_TRACING",
        "LANGCHAIN_TRACING",
        "OPENAI_ORG_ID",
        "OPENAI_PROJECT_ID",
        "OPENAI_WEBHOOK_SECRET",
        "OPENAI_LOG",
        "OPENAI_API_KEY",
        "OPENAI_BASE_URL"
      ],
      "net": true
    }
  }
}
