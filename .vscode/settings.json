{
  "cSpell.words": ["chromadb"],
  "deno.enablePaths": ["./deno.json"],
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "[javascript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit"
  },
  "deno.enable": true,
  "notebook.formatOnSave.enabled": true,
  "notebook.codeActionsOnSave": {
    "source.fixAll": "explicit"
  }
}
